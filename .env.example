# Copiar a .env y rellenar valores reales
# NOTA: JWT_SECRET no debe contener signo exclamacion para evitar problemas con bash
JWT_SECRET=cambia-esto-por-una-clave-larga-y-segura-de-32-caracteres-sin-signo-exclamacion
# Usa $HOME en las rutas; start.sh lo expande automaticamente
FBS_DB_PATH=$HOME/.fbs/fbs.db
FBS_HISTORIAL_PATH=$HOME/.fbs/registro/historial.jsonl
FBS_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
JWT_EXPIRE_MINUTES=1440
UVICORN_PORT=8000
